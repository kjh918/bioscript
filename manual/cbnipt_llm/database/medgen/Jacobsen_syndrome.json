    "medgen_uid": "162878",
    "disease_name": "11q partial monosomy syndrome (JBS)",
    "concept_id": "C0795841",
    "disease_type": "Disease or Syndrome",
    "definition": "Jacobsen syndrome (JBS) is a contiguous gene deletion syndrome with major clinical features of growth retardation, psychomotor retardation, trigonocephaly, divergent intermittent strabismus, epicanthus, telecanthus, broad nasal bridge, short nose with anteverted nostrils, carp-shaped upper lip, retrognathia, low-set dysmorphic ears, bilateral camptodactyly, hammertoes, and isoimmune thrombocytopenia (Fryns et al., 1986, Epstein, 1986). [from OMIM ]",
    "synonyms": [
      "CHROMOSOME 11q DELETION SYNDROME",
      "Jacobsen Distal 11q Deletion Syndrome",
      "JBS"
    ],
